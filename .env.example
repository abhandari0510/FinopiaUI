NEXT_PUBLIC_SITE_URL=https://finopiaservices.com
NEXT_PUBLIC_FINOPIA_API_BASE_URL=https://api.finopiaservices.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx
NEXT_PUBLIC_BOOK_SKU=paishache-shahanpan

# Grafana Frontend Observability - browser-safe values.
NEXT_PUBLIC_GRAFANA_FARO_ENABLED=true
NEXT_PUBLIC_GRAFANA_FARO_URL=https://faro-collector-prod-ap-south-1.grafana.net/collect/1c96b8de4ebf873a96f363e80f6a1027
NEXT_PUBLIC_GRAFANA_APP_NAME=FinOpia UI
NEXT_PUBLIC_GRAFANA_APP_VERSION=1.0.0
NEXT_PUBLIC_GRAFANA_ENVIRONMENT=production
NEXT_PUBLIC_GRAFANA_SESSION_SAMPLING_RATE=1

# Grafana source-map upload - server/build-time only. Do not expose this in browser code.
GRAFANA_FARO_SOURCE_MAP_UPLOAD_ENABLED=true
GRAFANA_FARO_SOURCE_MAP_ENDPOINT=https://faro-api-prod-ap-south-1.grafana.net/faro/api/v1
GRAFANA_FARO_APP_ID=1906
GRAFANA_FARO_STACK_ID=1706338
GRAFANA_FARO_SOURCE_MAP_API_KEY=replace-with-grafana-api-key
GRAFANA_FARO_SOURCE_MAP_VERBOSE=true

# Keep Razorpay secret, database, SMTP, Shiprocket, JWT values, and private Grafana keys only in backend/build environments.
